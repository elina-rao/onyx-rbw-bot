{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "18"
  },
  "buildAptPackages": [
    "build-essential",
    "libcairo2-dev",
    "libpango1.0-dev",
    "libjpeg-dev",
    "libgif-dev",
    "librsvg2-dev",
    "libpixman-1-dev"
  ],
  "deploy": {
    "aptPackages": [
      "libcairo2",
      "libpango1.0-0",
      "libpangocairo-1.0-0",
      "libjpeg62-turbo",
      "libgif7",
      "librsvg2-2",
      "libpixman-1-0",
      "libfontconfig1"
    ]
  }
}
