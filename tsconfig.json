{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "removeComments": true,
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "discord.js": ["node_modules/discord.js/typings/index.d.ts"]
    }
  },
  "exclude": [
    "**/*.ts.mongo",
    "src/utils 2.ts",
    "src/index 2.ts"
  ]
}
